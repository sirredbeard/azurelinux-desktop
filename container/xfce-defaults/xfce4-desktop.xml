<?xml version="1.0" encoding="UTF-8"?>
<!-- Bluecurve-era wallpaper. Entries cover the monitor names Xvnc and Xorg
     sessions produce; unmatched entries are ignored. -->
<channel name="xfce4-desktop" version="1.0">
  <property name="backdrop" type="empty">
    <property name="screen0" type="empty">
      <property name="monitor0" type="empty">
        <property name="workspace0" type="empty">
          <property name="last-image" type="string" value="/usr/share/backgrounds/bluecurve/lightrays.png"/>
        </property>
      </property>
      <property name="monitorVNC-0" type="empty">
        <property name="workspace0" type="empty">
          <property name="last-image" type="string" value="/usr/share/backgrounds/bluecurve/lightrays.png"/>
        </property>
      </property>
    </property>
  </property>
  <!-- Home and Trash on the desktop, like Red Hat 9. -->
  <property name="desktop-icons" type="empty">
    <property name="file-icons" type="empty">
      <property name="show-home" type="bool" value="true"/>
      <property name="show-trash" type="bool" value="true"/>
      <property name="show-filesystem" type="bool" value="false"/>
      <property name="show-removable" type="bool" value="false"/>
    </property>
  </property>
</channel>
